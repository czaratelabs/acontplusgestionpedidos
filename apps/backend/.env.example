# =============================================================================
# Configuración de base de datos - Supabase / PostgreSQL
# =============================================================================
# Copia este archivo a .env y reemplaza con tus credenciales reales.
# En Supabase: Project Settings > Database
# =============================================================================

# Conexión directa (puerto 5432)
DB_HOST=db.xxxxxxxx.supabase.co
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=tu-password-de-base-de-datos
DB_DATABASE=postgres

# SSL requerido para Supabase
DB_SSL=true

# Alternativa: URL de conexión completa (sobrescribe las variables anteriores si está definida)
# IMPORTANTE: usar host db.xxx.supabase.co (conexión directa), NO la URL de la API (https://xxx.supabase.co)
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres

# =============================================================================
# Seed inicial (npm run seed): usuario Super Admin para primer acceso
# =============================================================================
# SEED_SUPER_ADMIN_EMAIL=admin@tudominio.com
# SEED_SUPER_ADMIN_PASSWORD=tu-password-seguro
